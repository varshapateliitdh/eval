{
	"name": "AgentFromFirstPrinciples",
	"build": {
		"context": "..",
		"dockerfile": "Dockerfile"
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"charliermarsh.ruff",
				"tamasfe.even-better-toml",
				"ms-toolsai.jupyter",
				"ms-azuretools.vscode-docker",
				"DavidAnson.vscode-markdownlint",
				"yzhang.markdown-all-in-one",
				"stkb.rewrap"
			]
		},
		"settings": {
			"python.defaultInterpreterPath": "${containerWorkspaceFolder}/.venv/bin/python3.12"
		}
	},
	"forwardPorts": [8000],
	"postCreateCommand": "bash ./.devcontainer/postCreateCommands.sh ${containerWorkspaceFolder}",

}
